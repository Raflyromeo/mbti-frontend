# Konfigurasi Supabase
# Dapatkan URL dan Key ini dari Dasbor Supabase Anda (Project Settings -> API)

# URL proyek Supabase (contoh: https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon Key Supabase (Kunci publik untuk akses klien/browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Publishable Key (Kunci publik alternatif, opsional)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service Role Key (SANGAT RAHASIA - Kunci admin untuk mem-bypass RLS)
# Jangan pernah mengekspos kunci ini ke browser/frontend publik!
SUPABASE_SERVICE_ROLE_KEY=

# Konfigurasi Backend API Python
# URL dari Backend Pakar MBTI Anda (contoh: https://mbti-backend.up.railway.app)
# Kosongkan jika berjalan di localhost (otomatis mengarah ke http://localhost:8000)
NEXT_PUBLIC_API_URL=
